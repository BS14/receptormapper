# ── DynamoDB ─────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=fake
AWS_SECRET_ACCESS_KEY=fake
# Local DynamoDB container — remove for production (SDK uses real AWS)
AWS_ENDPOINT_URL=http://localhost:8000
DYNAMODB_JOBS_TABLE=prediction_jobs
DYNAMODB_CACHE_TABLE=prediction_cache

# ── FastAPI (prediction server) ───────────────────────────────────────────────
# Local: points at Docker container running main.py
# Production: EC2 public IP or domain, e.g. http://1.2.3.4:8000
FASTAPI_URL=http://localhost:8000

# ── Auth (optional in dev) ────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-in-prod
