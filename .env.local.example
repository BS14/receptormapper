# ── Local dev environment ─────────────────────────────────────────────────────
# Used by docker-compose.dev.yml
# Never commit real credentials here

# AWS (fake for local DynamoDB)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=fake
AWS_SECRET_ACCESS_KEY=fake
AWS_ENDPOINT_URL=http://dynamo:8000

# DynamoDB tables
DYNAMODB_JOBS_TABLE=prediction_jobs
DYNAMODB_CACHE_TABLE=prediction_cache

# FastAPI (container-to-container name)
FASTAPI_URL=http://api:8000

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-in-prod
